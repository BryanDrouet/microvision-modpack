# Cloudflare R2 Configuration Template
# Remplissez ces valeurs avec vos credentials Cloudflare R2

# Votre Account ID Cloudflare (trouvable dans le dashboard R2)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Votre API Token Cloudflare avec permissions R2 (créé dans le dashboard)
CLOUDFLARE_API_TOKEN=your_api_token_here

# Nom du bucket R2 que vous avez créé
CLOUDFLARE_BUCKET_NAME=microvision-modpack

# URL de base du bucket R2
# Format: https://{account-id}.r2.cloudflarestorage.com
# Ou votre Custom Domain personnalisé
CLOUDFLARE_BUCKET_URL=https://your_account_id.r2.cloudflarestorage.com
